# Gorgias (required when not using DRY_RUN)
GORGIAS_EMAIL=your-agent-or-system-email@example.com
GORGIAS_API_KEY=
GORGIAS_DOMAIN=yourstore

# Abacus getChatResponse (.../api/getChatResponse?deploymentToken=...&deploymentId=...)
ABACUS_DEPLOYMENT_ID=
ABACUS_DEPLOYMENT_TOKEN=

# Optional
ABACUS_API_BASE_URL=https://apps.abacus.ai
ABACUS_TIMEOUT_MS=20000
GORGIAS_TIMEOUT_MS=20000

# Chat widget link rendering: plain | html | markdown (default: html)
# Use "html" to send <a href="..."> in body_html so links are clickable in Shopify Chat Widget.
CHAT_LINK_FORMAT=html

# Local smoke test: skip real Abacus/Gorgias calls (no keys needed)
DRY_RUN=true
